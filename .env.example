# Copy this file to .env.local and fill values.
# Do not commit .env.local.

# 1 to enable LLM, 0 to force local advisor.
USE_LLM=1

# Generic provider settings (OpenAI-compatible Chat Completions API).
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_ENDPOINT=/chat/completions
LLM_MODEL=gpt-4o
# Optional multi-provider profiles (different API endpoints/models/keys).
# If LLM_PROFILE_PICK is set, selected profile overrides LLM_API_KEY/BASE_URL/MODEL.
# LLM_PROFILE_1_NAME=openai
# LLM_PROFILE_1_API_KEY=sk-...
# LLM_PROFILE_1_BASE_URL=https://api.openai.com/v1
# LLM_PROFILE_1_ENDPOINT=/chat/completions
# LLM_PROFILE_1_MODEL=gpt-4o
# LLM_PROFILE_2_NAME=moonshot
# LLM_PROFILE_2_API_KEY=sk-...
# LLM_PROFILE_2_BASE_URL=https://api.moonshot.ai/v1
# LLM_PROFILE_2_ENDPOINT=/chat/completions
# LLM_PROFILE_2_MODEL=moonshot-v1-8k
# LLM_PROFILE_3_NAME=qwen
# LLM_PROFILE_3_API_KEY=sk-...
# LLM_PROFILE_3_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# LLM_PROFILE_3_ENDPOINT=/chat/completions
# LLM_PROFILE_3_MODEL=qwen3.5-flash
# LLM_PROFILE_4_NAME=gemini
# LLM_PROFILE_4_API_KEY=your_gemini_api_key
# LLM_PROFILE_4_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_PROFILE_4_ENDPOINT=/chat/completions
# LLM_PROFILE_4_MODEL=gemini-2.0-flash
# LLM_PROFILE_PICK=1
# Optional fallback profile (switches only on request error/timeout).
# LLM_FALLBACK_PROFILE_PICK=4
# Optional model candidates + picker (1/2/3 or exact model string).
# LLM_MODEL_1=gpt-4o
# LLM_MODEL_2=gpt-4.1
# LLM_MODEL_3=gpt-4o-mini
# LLM_MODEL_PICK=1
# Moonshot/Kimi models may require temperature=1.
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=900
LLM_TIMEOUT_MS=30000
LLM_RETRY_COUNT=3
LLM_RETRY_BACKOFF_MS=600
SIM_HISTORY_BRIEF_DAYS=2
SIM_HISTORY_BRIEF_MAX_ITEMS=8
SIM_SPEECH_MAX_CHARS=80
SIM_SUMMARY_MAX_CHARS=120
SIM_RATIONALE_MAX_CHARS=160

# Simulation controls
SIM_STEPS=8
# 0 means all active agents each tick; set small number (e.g. 3-5) for fast debugging.
SIM_MAX_ACTORS_PER_TICK=0
# More realistic activity density (not everyone acts each phase).
SIM_ACTIVE_RATIO_PER_TICK=0.45
# sequential(default) for stronger causality; parallel for speed.
SIM_PLANNING_MODE=sequential
# Optional seed for reproducible randomness across runs.
# SIM_RANDOM_SEED=42
# Random perturbation for agreement/decision outcomes.
SIM_DECISION_NOISE=0.15
# Random perturbation for battle outcome probability.
SIM_BATTLE_NOISE=0.2
# Number of parallel LLM planning calls inside one tick.
SIM_LLM_CONCURRENCY=4
# hierarchical(default): main-event + sub-event orchestration with SQLite logs.
SIM_ORCHESTRATION_MODE=hierarchical
# Persistent global simulation database.
SIM_DB_PATH=/tmp/world-simulator/sim.db
# Editable generic framework file (prompt/style/role-keyword policy).
SIM_FRAMEWORK_FILE=./config/simulation-framework.json
# 1: enable bootstrap cache reuse (avoid repeated extraction token cost).
SIM_BOOTSTRAP_CACHE=1
# Optional bootstrap mode from user-uploaded source materials (comma-separated files or directories).
# Supported file extensions: .txt,.md,.markdown,.json,.yaml,.yml,.csv,.tsv,.html,.htm
# SIM_SOURCE_FILES=/abs/path/novel.txt,/abs/path/worldbook,/abs/path/notes.md
# Optional timeline start node id or label for bootstrap mode.
# SIM_START_NODE=
# 1: run bootstrap extraction only, print candidates, then exit without simulation.
# SIM_BOOTSTRAP_ONLY=0
# 1: save complete prompt+raw output for each LLM call (default follows DEBUG_MODE).
# SIM_TRACE_LLM_IO=1
# Optional trace output directory (default under system temp).
# SIM_TRACE_DIR=/tmp/world-simulator/llm-trace
# Optional: custom directory for run history markdown dumps.
# SIM_HISTORY_DIR=/tmp/world-simulator
DEBUG_MODE=0
